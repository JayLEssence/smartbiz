generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id          String   @id @default(cuid())
  name        String
  industry    String?   // e.g. "Retail", "Wholesale", "Restaurant"
  email       String?
  phone       String?
  address     String?
  logoUrl     String?
  plan        String    @default("free")  // free, starter, pro
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  branches    Branch[]
  users       User[]
  products    Product[]
  sales       Sale[]
}

model Branch {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  address     String?
  phone       String?
  isHeadOffice Boolean @default(false)
  isActive    Boolean  @default(true)
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company         Company         @relation(fields: [companyId], references: [id])
  users           User[]
  products        Product[]
  inventoryBatches InventoryBatch[]
  sales           Sale[]
  shrinkages      Shrinkage[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("Employee") // CompanyAdmin, Manager, Employee
  branchId     String
  companyId    String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branch  Branch @relation(fields: [branchId], references: [id])
  company Company @relation(fields: [companyId], references: [id])
  sales   Sale[]
}

model Product {
  id                 String   @id @default(cuid())
  name               String
  sku                String
  barcode            String?
  category           String
  currentStockLevel  Int      @default(0)
  reorderThreshold   Int      @default(10)
  defaultSalePrice   Float    @default(0)
  branchId           String
  companyId          String
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  branch          Branch          @relation(fields: [branchId], references: [id])
  company         Company         @relation(fields: [companyId], references: [id])
  inventoryBatches InventoryBatch[]
  saleItems       SaleItem[]
  shrinkages      Shrinkage[]

  @@unique([sku, branchId])
}

model InventoryBatch {
  id                String   @id @default(cuid())
  productId         String
  quantityAdded     Int
  purchasePricePerUnit Float
  supplier          String?
  dateReceived      DateTime @default(now())
  branchId          String
  createdAt         DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])
}

model Sale {
  id         String   @id @default(cuid())
  totalAmount Float
  discount   Float    @default(0)
  saleDate   DateTime @default(now())
  userId     String
  branchId   String
  companyId  String
  createdAt  DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id])
  branch    Branch     @relation(fields: [branchId], references: [id])
  company   Company    @relation(fields: [companyId], references: [id])
  saleItems SaleItem[]
}

model SaleItem {
  id              String   @id @default(cuid())
  saleId          String
  productId       String
  quantitySold    Int
  salePricePerUnit  Float
  costPricePerUnit  Float
  createdAt       DateTime @default(now())

  sale    Sale    @relation(fields: [saleId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Shrinkage {
  id           String   @id @default(cuid())
  productId    String
  quantityLost Int
  reason       String   // Stolen, Expired, Damaged
  dateRecorded DateTime @default(now())
  branchId     String
  createdAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])
}
