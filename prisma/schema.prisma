generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id              String   @id @default(cuid())
  name            String
  industry        String?
  email           String?
  phone           String?
  address         String?
  logoUrl         String?
  plan            String   @default("free")
  isActive        Boolean  @default(true)
  currency        String   @default("TZS")   // Local currency code: TZS, KES, UGX, etc.
  currencySymbol  String   @default("TSh")   // Local currency symbol
  country         String   @default("Tanzania")
  exchangeRate    Float    @default(2570)     // Exchange rate: 1 USD = X local currency
  twoFactorEnabled Boolean @default(false)    // Company-wide 2FA requirement
  dataRetentionDays Int    @default(365)      // Data retention policy in days
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  branches    Branch[]
  users       User[]
  products    Product[]
  sales       Sale[]
  expenses    Expense[]
  suppliers   Supplier[]
  customers   Customer[]
  notifications Notification[]
  auditLogs   AuditLog[]
  sessions    Session[]
}

model Branch {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  address     String?
  phone       String?
  isHeadOffice Boolean @default(false)
  isActive    Boolean  @default(true)
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company         Company         @relation(fields: [companyId], references: [id])
  users           User[]
  products        Product[]
  inventoryBatches InventoryBatch[]
  sales           Sale[]
  shrinkages      Shrinkage[]
  expenses        Expense[]
  customers       Customer[]
  notifications   Notification[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("Employee")
  branchId     String
  companyId    String
  isActive     Boolean  @default(true)
  twoFactorSecret String?          // TOTP secret for 2FA
  twoFactorEnabled Boolean @default(false)
  lastLoginAt  DateTime?           // Track last login time
  lastLoginIp  String?             // Track last login IP
  passwordChangedAt DateTime?      // When password was last changed
  mustChangePassword Boolean @default(false) // Force password change on next login
  failedLoginAttempts Int @default(0)        // Track failed login attempts
  lockedUntil DateTime?                      // Account lockout timestamp
  passwordResetToken String?                 // Token for password reset
  resetTokenExpiresAt DateTime?              // When the reset token expires
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branch   Branch   @relation(fields: [branchId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id])
  sales    Sale[]
  sessions Session[]
  auditLogs AuditLog[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String            // Hashed token for verification
  deviceInfo   String?           // Browser/device info
  ipAddress    String?           // IP address at session creation
  expiresAt    DateTime          // When the session expires
  isValid      Boolean  @default(true)
  createdAt    DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  company Company  @relation(fields: [companyId], references: [id])
  companyId String
}

model AuditLog {
  id           String   @id @default(cuid())
  action       String             // LOGIN_SUCCESS, USER_CREATED, etc.
  userId       String?            // Who performed the action
  userEmail    String?            // Email at time of action
  companyId    String?            // Which company
  branchId     String?            // Which branch
  details      String?            // Additional details
  ipAddress    String?            // Request IP
  userAgent    String?            // Browser user agent
  severity     String  @default("info") // info, warning, critical
  createdAt    DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])
}

model Product {
  id                 String   @id @default(cuid())
  name               String
  sku                String
  barcode            String?
  category           String
  currentStockLevel  Int      @default(0)
  reorderThreshold   Int      @default(10)
  defaultSalePrice   Float    @default(0)
  branchId           String
  companyId          String
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  branch          Branch          @relation(fields: [branchId], references: [id])
  company         Company         @relation(fields: [companyId], references: [id])
  inventoryBatches InventoryBatch[]
  saleItems       SaleItem[]
  shrinkages      Shrinkage[]

  @@unique([sku, branchId])
}

model InventoryBatch {
  id                String   @id @default(cuid())
  productId         String
  quantityAdded     Int
  purchasePricePerUnit Float
  supplierName       String?          // Legacy text field
  dateReceived      DateTime @default(now())
  branchId          String
  supplierId        String?
  createdAt         DateTime @default(now())

  product  Product  @relation(fields: [productId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])
}

model Sale {
  id            String   @id @default(cuid())
  totalAmount   Float
  discount      Float    @default(0)
  saleDate      DateTime @default(now())
  userId        String
  branchId      String
  companyId     String
  paymentMethod String   @default("Cash")  // Cash, M-Pesa, Tigo Pesa, Airtel Money, Card, Credit
  customerName  String?
  receiptNumber String?
  createdAt     DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id])
  branch    Branch     @relation(fields: [branchId], references: [id])
  company   Company    @relation(fields: [companyId], references: [id])
  saleItems SaleItem[]
}

model SaleItem {
  id              String   @id @default(cuid())
  saleId          String
  productId       String
  quantitySold    Int
  salePricePerUnit  Float
  costPricePerUnit  Float
  createdAt       DateTime @default(now())

  sale    Sale    @relation(fields: [saleId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Shrinkage {
  id           String   @id @default(cuid())
  productId    String
  quantityLost Int
  reason       String
  dateRecorded DateTime @default(now())
  branchId     String
  createdAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  category    String   // Rent, Utilities, Salaries, Transport, Supplies, Maintenance, Other
  description String
  amount      Float
  date        DateTime @default(now())
  branchId    String
  companyId   String
  receiptUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch  Branch  @relation(fields: [branchId], references: [id])
  company Company @relation(fields: [companyId], references: [id])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  companyId String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company         Company         @relation(fields: [companyId], references: [id])
  inventoryBatches InventoryBatch[]
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  email         String?
  phone         String?
  address       String?
  loyaltyPoints Int      @default(0)
  creditBalance Float    @default(0)
  creditLimit   Float    @default(0)
  branchId      String
  companyId     String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch  Branch  @relation(fields: [branchId], references: [id])
  company Company @relation(fields: [companyId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // LowStock, HighShrinkage, DailySummary, CreditAlert, ExpenseAlert
  title     String
  message   String
  isRead    Boolean  @default(false)
  companyId String
  branchId  String?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  branch  Branch? @relation(fields: [branchId], references: [id])
}
